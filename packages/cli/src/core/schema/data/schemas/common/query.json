                  "$ref": "#/$defs/options"
                },
                {
                  "$ref": "#/$defs/expression"
                },
                {
                  "$ref": "#/$defs/expression"
                }
              ],
              "items": {
                "$ref": "#/$defs/expression"
              },
              "minItems": 4
            }
          },
          {
            "if": {
              "prefixItems": [
                {
                  "const": "not"
